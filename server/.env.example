# Server environment
NODE_ENV=production
PORT=5000

# CORS — comma-separated list of allowed frontend origins
# Set to your Render static site URL after deploying the frontend
ALLOWED_ORIGINS=https://your-tolz-client.onrender.com

# Base URL for the URL shortener — REQUIRED in production
# Set to the domain where short links will be resolved (backend or custom domain)
# Without this, the URL shortener will throw a hard error on every request
APP_BASE_URL=https://your-tolz-api.onrender.com

# Optional: Redis connection string for persistent URL shortener storage
# Without this, short URLs are stored in memory and lost on every restart/spin-down
# Get this from Render > New > Redis after creating a Redis instance
# REDIS_URL=redis://red-xxxxx:6379
